{
  "name": "@mara/server",
  "version": "3.0.13",
  "private": true,
  "type": "module",
  "// files": "Allowlist for `pnpm deploy` (the packaged server). Keeps the build output only — never the runtime data/ (chat history + identity tokens) or .turbo logs.",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx --watch src/main.ts",
    "serve": "node --import tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mara/protocol": "workspace:*",
    "pino": "^9.5.0",
    "sirv": "^3.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
  }
}
