# Development server config — loaded only when running the server from this
# directory (i.e. `pnpm dev`), since loadConfigFile() reads `mara.config` from the
# working directory. Names this instance so it's easy to identify while testing.
# The packaged server uses its OWN mara.config next to the launcher, not this one.
MARA_SERVER_NAME=Mara 3 Development
