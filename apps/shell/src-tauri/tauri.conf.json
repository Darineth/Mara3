{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mara 3",
  "version": "3.0.0",
  "identifier": "com.mara.chat",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @mara/web dev",
    "beforeBuildCommand": "pnpm --filter @mara/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Mara 3",
        "width": 980,
        "height": 720,
        "minWidth": 480,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws: wss:; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://releases.mara.example/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGQzM3MDAwNkNBMTY0NDUKUldSRlpLRnNBSEREVDM3RnFpb3JKTnRnVk1wS0JiVUdNZmJXU1JjRzRaTWJEcVMrLzFmMFlQSEIK"
    }
  }
}
