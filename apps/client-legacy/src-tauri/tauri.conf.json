{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../bootstrap",
    "distDir": "../bootstrap",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Mara 3",
    "version": "3.0.4"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": "^https?://"
      }
    },
    "windows": [],
    "security": {
      "csp": null,
      "dangerousUseHttpScheme": true
    },
    "bundle": {
      "active": false,
      "identifier": "com.mara.chat.legacy",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
