  },
  "dependencies": {
    "@mara/chat-render": "workspace:*",
    "@mara/client-core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.1"
