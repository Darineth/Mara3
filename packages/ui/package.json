{
  "name": "@mara/ui",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "echo \"@mara/ui is consumed as source by Vite\"",
