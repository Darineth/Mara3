{
  "name": "mara",
  "version": "3.0.25",
  "private": true,
  "description": "Mara 3 — cross-platform chat (TypeScript / Svelte / Tauri 2).",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "pnpm --filter @mara/web build && pnpm --filter @mara/server serve",
    "package": "node scripts/package.mjs",
    "package:legacy": "node scripts/package-legacy.mjs",
    "package:linux": "node scripts/package-linux.mjs",
    "package:zip": "node scripts/zip-dist.mjs",
    "package:all": "node scripts/package.mjs && node scripts/package-legacy.mjs && node scripts/package-linux.mjs --optional && node scripts/zip-dist.mjs",
    "release:github": "node scripts/release-github.mjs",
    "bump": "node scripts/bump-version.mjs",
    "version:check": "node scripts/bump-version.mjs --check",
    "icons:gen": "node scripts/generate-icons.mjs",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,svelte,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,svelte,js,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
