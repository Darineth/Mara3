# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.svelte-kit/
.turbo/
*.tsbuildinfo

# Logo/brand working files & concept art (the canonical sources live in resources/)
references/

# Runtime upload cache (server-local image hosting)
apps/server/uploads/

# Persisted message history (server-local)
apps/server/data/

# Tauri / Rust
apps/shell/src-tauri/target/
# gen/android is committed (Tauri's nested .gitignores exclude build artifacts); only the derived ACL schemas are ignored
apps/shell/src-tauri/gen/schemas/
# App-command permissions autogenerated from build.rs (AppManifest) — derived, like gen/
apps/shell/src-tauri/permissions/autogenerated/
apps/client-legacy/src-tauri/target/
apps/client-legacy/src-tauri/gen/
# Pinned WebView2 fixed runtime for the Win7 client (~120 MB, downloaded, not committed)
apps/client-legacy/src-tauri/webview2-runtime/

# Updater signing — keep the public key, never commit the private key
apps/shell/.tauri/*.key

# Test / coverage
coverage/
TestApps/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Env
.env
.env.*
!.env.example

# Runtime data
apps/server/data/
# Keep the custom-emoji folder in the repo (so it's there to drop files into), but
# ignore whatever the operator puts in it.
apps/server/emoji/*
!apps/server/emoji/.gitkeep

# Claude
.claude